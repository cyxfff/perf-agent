OPENAI_API_KEY=
PERF_AGENT_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
PERF_AGENT_TIMEOUT_SEC=20
# Set to 1 for host-only analysis without probing adb devices.
PERF_AGENT_DISABLE_ADB=0

# OpenAI-compatible fallback names also supported.
LLM_API_KEY=
LLM_MODEL_ID=
LLM_BASE_URL=

# DeepSeek OpenAI-compatible settings are also supported.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
